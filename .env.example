# =============================================================================
# JonOps Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.
# See SETUP.md for detailed instructions on getting each API key.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Core Services
# -----------------------------------------------------------------------------

# Anthropic API (required for Claude — the AI that powers everything)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxx

# WordPress (required for content publishing)
WP_URL=https://yourdomain.com
WP_USERNAME=your_wordpress_username
WP_PASSWORD=your_wordpress_app_password

# Airtable (required for data storage)
AIRTABLE_API_KEY=pat_xxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Airtable Table IDs (created by scripts/setup/create-airtable-tables.py)
AIRTABLE_KEYWORDS_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_CONTENT_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_RESEARCH_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_PUBLISHED_POSTS_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_SOCIAL_QUEUE_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_SOCIAL_POSTS_LOG_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_NEWSLETTER_QUEUE_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_NEWSLETTER_LOG_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_MARKET_INTEL_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_OUTREACH_QUERIES_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_OUTREACH_LEADS_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_B2B_QUERIES_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_B2B_LEADS_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_GENERATED_IMAGES_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_REFERENCE_IMAGES_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_LEADS_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_SOCIAL_MINING_QUEUE_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_SOCIAL_MINING_DRAFTS_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_SOCIAL_MINING_LOG_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_GSC_OPPORTUNITIES_TABLE=tblXXXXXXXXXXXXXX
AIRTABLE_GA4_INSIGHTS_TABLE=tblXXXXXXXXXXXXXX

# Image Generation (required for featured images)
REPLICATE_API=r8_xxxxxxxxxxxxxx
TINIFY_API=xxxxxxxxxxxxxx

# Cloudinary (required for social media image hosting)
# Meta (Facebook/Instagram) APIs reject WebP images. WordPress may auto-convert
# uploads to WebP. Cloudinary provides permanent JPEG URLs that Meta can fetch.
# Free tier: 25k transformations + 25GB storage/month — plenty for most businesses.
# Get credentials at: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -----------------------------------------------------------------------------
# RECOMMENDED — Notifications & Task Management
# -----------------------------------------------------------------------------

# Telegram (operator notifications + chat interface)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789
TELEGRAM_DAILY_TOKEN_BUDGET=500000
TELEGRAM_DAEMON_ENABLED=true

# Asana (task management and workflow)
ASANA_API_KEY=1/1234567890:abcdef
ASANA_PROJECT_GID=1234567890123456
ASANA_INBOX_SECTION_GID=1234567890123456
ASANA_TODO_SECTION_GID=1234567890123456
ASANA_DONE_SECTION_GID=1234567890123456

# -----------------------------------------------------------------------------
# OPTIONAL — Additional Integrations
# -----------------------------------------------------------------------------

# Sendy (self-hosted email newsletters)
# SENDY_URL=https://your-sendy-install.com
# SENDY_API_KEY=xxxx
# SENDY_LIST_MAIN=list_id
# SENDY_FROM_NAME=Your Business Name
# SENDY_FROM_EMAIL=newsletter@yourdomain.com
# SENDY_REPLY_TO=hello@yourdomain.com

# Metricool (social media scheduling)
# METRICOOL_API_TOKEN=xxxx
# METRICOOL_BLOG_ID=xxxx

# Instantly (email outreach campaigns)
# INSTANTLY_API_KEY=xxxx
# INSTANTLY_CAMPAIGN_ID=xxxx
# INSTANTLY_FROM_EMAIL=outreach@yourdomain.com

# Google OAuth (Gmail + Search Console + Analytics 4 — single token covers all three)
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxx
# GOOGLE_REFRESH_TOKEN=xxxx
# GA4_PROPERTY_ID=123456789  # Optional. If unset, gsc-ga4-sweep enumerates accountSummaries and matches by domain. Set explicitly when multiple GA4 properties match the brand (e.g. UtamaSpice has 3).
# SITE_URL=https://yourdomain.com/  # Canonical brand URL with trailing slash. Used by gsc-ga4-sweep to match the GSC URL-prefix property. Defaults to WP_URL with trailing slash if unset.
# BRAND_NAME=Your Brand  # Used by gsc-ga4-sweep for Airtable Brand field and brand-name query detection. Defaults to CLAUDE.md H1 if unset.

# DataForSEO (keyword research)
# DATAFORSEO_LOGIN=xxxx
# DATAFORSEO_PASSWORD=xxxx

# Firecrawl (web scraping)
# FIRECRAWL_API_KEY=fc-xxxx

# ScrapeCreators (Reddit/social discovery)
# SCRAPECREATORS_API_KEY=xxxx

# Jamendo (royalty-free BGM for video pipeline)
# JAMENDO_CLIENT_ID=xxxx

# ElevenLabs (text-to-speech voiceover for video pipeline)
# ELEVENLABS_API=xxxx
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb  # Default: George. See https://elevenlabs.io/voice-library

# Metricool (user ID for Pinterest board lookup)
# METRICOOL_USER_ID=xxxx

# -----------------------------------------------------------------------------
# TIMEZONE
# -----------------------------------------------------------------------------

# Timezone offset in hours from UTC (for schedule.json)
# Examples: -5 (EST), -8 (PST), +1 (CET), +8 (SGT)
TZ_OFFSET_HOURS=0
